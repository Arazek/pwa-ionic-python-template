# =============================================================================
# PWA Template — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
DOMAIN=localhost
# TLS mode: local (self-signed) | letsencrypt
TLS_MODE=local
ACME_EMAIL=your@email.com

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=app_db

# Keycloak gets its own database on the same postgres instance
KEYCLOAK_DB=keycloak_db
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Keycloak
# -----------------------------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme
# Internal URL used by backend to verify tokens (container-to-container)
KEYCLOAK_INTERNAL_URL=http://keycloak:8080
# Public URL used by frontend
KEYCLOAK_PUBLIC_URL=https://localhost:4443/auth
KEYCLOAK_REALM=pwa

# Social Identity Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Backend (FastAPI)
# -----------------------------------------------------------------------------
SECRET_KEY=changeme-use-openssl-rand-hex-32
BACKEND_CORS_ORIGINS=["https://localhost", "https://localhost:4443"]
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# pgAdmin
# -----------------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=changeme
